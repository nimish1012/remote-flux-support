# =============================================================================
# Environment Configuration for Image Generator
# =============================================================================
# Variable            | Default                 | Description
# --------------------|-------------------------|----------------------------------
# MODEL_NAME          | black-forest-labs/...  | HuggingFace model for image gen
# FLUX_SERVER_PORT    | 7001                    | Port for flux_server.py (remote ML)
# API_SERVER_PORT     | 8000                    | Port for image_api.py
# REMOTE_FLUX_URL     | http://127.0.0.1:7001   | URL to connect to remote flux
# DEFAULT_WIDTH       | 768                     | Default image width in pixels
# DEFAULT_HEIGHT      | 768                     | Default image height in pixels
# DEFAULT_STEPS       | 20                      | Inference steps (quality vs speed)
# DEFAULT_GUIDANCE_SCALE | 2.5                  | CFG scale (prompt adherence)
# VRAM_FRACTION       | 0.90                    | GPU memory fraction (0-1)
# PREVIEW_BLUR_RADII  | 10,5,2,0                | Blur radii for progressive preview
# PREVIEW_DELAY       | 0.4                     | Seconds between preview frames
# =============================================================================

# Model Configuration
MODEL_NAME=black-forest-labs/FLUX.1-Krea-dev

# Server Ports
FLUX_SERVER_PORT=7001
API_SERVER_PORT=8000

# Remote Server URL (for remote mode)
REMOTE_FLUX_URL=http://127.0.0.1:7001

# Default Generation Parameters
DEFAULT_WIDTH=768
DEFAULT_HEIGHT=768
DEFAULT_STEPS=20
DEFAULT_GUIDANCE_SCALE=2.5

# GPU Configuration
VRAM_FRACTION=0.90

# Preview Streaming (blur radii for progressive preview)
PREVIEW_BLUR_RADII=10,5,2,0
PREVIEW_DELAY=0.4
